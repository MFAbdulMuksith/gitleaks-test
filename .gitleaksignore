# =============================================================================
# .gitleaksignore — Suppress specific findings by their unique fingerprint.
#
# WHEN TO USE THIS FILE:
#   Use when a finding is a confirmed false positive that cannot be suppressed
#   with #gitleaks:allow (because you don't own the file) or an allowlist path.
#
# HOW TO GET FINGERPRINTS:
#   gitleaks git --report-format json --report-path /tmp/report.json
#   cat /tmp/report.json | python3 -c "
#     import json, sys
#     for f in json.load(sys.stdin):
#         print(f['Fingerprint'], '|', f['RuleID'], '|', f['File'])
#   "
#
# FORMAT:  <commit>:<file>:<ruleID>:<line>   (dir scan)
#       or <commit>:<file>:<ruleID>:<line>   (git scan)
# =============================================================================

