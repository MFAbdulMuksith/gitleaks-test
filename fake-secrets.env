# =============================================================================
# fake-secrets.env — SAFE TEST FIXTURES FOR GITLEAKS VALIDATION
#
# Every value in this file is intentionally fake and triggers specific
# Gitleaks detection rules. None of these are real credentials.
# This file exists to PROVE that Gitleaks rules fire correctly.
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────
# Triggers: aws-access-token + aws-secret-access-key rules
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── GitHub ────────────────────────────────────────────────────────────────────
# Triggers: github-pat rule
GITHUB_TOKEN=ghp_1234567890abcdef1234567890abcdef12345678

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Triggers: internal-jwt-secret (custom rule)
JWT_SECRET=superSecretSigningKey_abc123XYZ_production_2024

# ── Database connection string ────────────────────────────────────────────────
# Triggers: database-connection-string (custom rule)
DATABASE_URL=postgres://admin:hunter2_supersecret@db.internal:5432/myapp

# ── Inline suppression ────────────────────────────────────────────────────────
# The #gitleaks:allow comment tells Gitleaks to SKIP this specific line.
# Use sparingly — only when you are 100% certain the value is not a real secret.
IGNORED_SECRET=abc123def456  #gitleaks:allow
