# =============================================================================
# fake-secrets.env — SAFE TEST FIXTURES (master branch — all suppressed)
#
# On master every line carrying a fake token uses #gitleaks:allow so that
# `gitleaks dir .` and `gitleaks git .` both exit 0 on clean commits.
#
# On the feature/test-secret branch these same files exist WITHOUT the
# #gitleaks:allow comments so Gitleaks Stage 1 deliberately fails there.
# =============================================================================

# Rule: aws-access-token
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE  #gitleaks:allow

# Rule: aws-secret-access-key
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY  #gitleaks:allow

# Rule: github-pat  (line 6 — confirmed finding in history)
GITHUB_TOKEN=ghp_1234567890abcdef1234567890abcdef12345678  #gitleaks:allow

# Rule: internal-jwt-secret  (custom)
JWT_SECRET=superSecretSigningKey_abc123XYZ_production_2024  #gitleaks:allow

# Rule: database-connection-string  (custom)
DATABASE_URL=postgres://admin:hunter2_supersecret@db.internal:5432/myapp  #gitleaks:allow

# This line has no secret — included only to show inline allow syntax
IGNORED_SECRET=abc123def456  #gitleaks:allow
