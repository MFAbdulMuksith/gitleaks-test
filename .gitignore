# ── Gitleaks scan output ─────────────────────────────────────────────────────
# These files are written by the scanner at runtime. They must never be
# committed because they may contain partial secret values from findings.
report.json
report.sarif
report.csv
report.xml
report.junit
git-report.json
results.json
results.sarif
*.sarif

