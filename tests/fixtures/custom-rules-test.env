# =============================================================================
# custom-rules-test.env — Phase 2: triggers all 3 custom rules and
#                          demonstrates all 5 suppression techniques
# =============================================================================
# IMPORTANT: this file lives on feature/custom-rules for testing purposes.
#            All intentionally-fake values here are suppressed by the
#            technique each section is documenting.
# =============================================================================

# ─── 3→2 DROP DEMO ─────────────────────────────────────────────────────────
# This GitHub PAT value matches TWO built-in rules simultaneously:
#   github-pat       ← specific rule, kept
#   generic-api-key  ← noisy duplicate, disabled via disabledRules
# Without disabledRules = ["generic-api-key"]: 2 findings on this one line.
# With    disabledRules = ["generic-api-key"]: 1 finding (github-pat only).
# Suppression here is Technique 1 (inline allow) so the branch stays clean.
GITHUB_TOKEN=ghp_1234567890abcdef1234567890abcdef12345678  #gitleaks:allow

# ─── TECHNIQUE 1: Inline #gitleaks:allow ────────────────────────────────────
# The company-api-key rule matches COMPANY_API_KEY_[A-Za-z0-9]{15,}.
# The inline comment tells Gitleaks to skip this specific line.
# Use case: a one-off known-safe value that cannot be moved to a test fixture.
COMPANY_API_KEY_inlineSuppressDemo1234567890  #gitleaks:allow

# ─── TECHNIQUE 2: .gitleaksignore fingerprint ───────────────────────────────
# The internal-jwt-secret rule fires on this line (no inline suppress).
# After the first scan, extract the fingerprint and add it to .gitleaksignore:
#
#   gitleaks dir . --report-format json --report-path /tmp/p2.json
#   jq -r '.[] | "\(.Fingerprint)  # \(.RuleID) — \(.File):\(.StartLine)"' \
#       /tmp/p2.json >> /home/abdul/gitleaks-test/.gitleaksignore
#
# Use case: a committed value in Git history that cannot be rewritten.
jwt_secret=fingerprint_demo_SigningKey_abc123XYZ_prod_2024

# ─── TECHNIQUE 3: Path-based [[rules.allowlists]] ────────────────────────────
# Demonstrated in tests/fixtures/test_db_false_positive.py:
# The database-connection-string rule has a per-rule path allowlist that
# suppresses all tests/*.py files. The same postgres:// URL that would fire
# in a .env file is silently ignored inside a Python test.
# (No example here — see test_db_false_positive.py)

# ─── TECHNIQUE 4: Stopword in [[rules.allowlists]] ───────────────────────────
# The company-api-key rule now has:
#   [[rules.allowlists]]
#   stopwords = ["changeme", "placeholder", "example", "test_key"]
# Gitleaks extracts the full regex match as the secret value and checks
# whether any stopword is a substring of it.
# "changeme" appears in "COMPANY_API_KEY_changeme..." → suppressed.
COMPANY_API_KEY_changeme12345678901234

# ─── TECHNIQUE 5: Regex match against full line ──────────────────────────────
# The database-connection-string rule now has a second [[rules.allowlists]]:
#   condition   = "OR"
#   regexTarget = "line"
#   regexes     = ['localhost', '127\.0\.0\.1', 'test_password']
# regexTarget = "line" evaluates the ENTIRE source line (not just the match).
# "localhost" appears on this line → finding is suppressed.
DATABASE_LOCAL=postgres://user:someSecretPassword123@localhost:5432/testdb
